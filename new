func, expected = COMMANDS[cmd]
if len(args) != expected:
    sys.exit(f"'{cmd}' attend {expected} argument(s), recu {len(args)}")

try:
    func(*args)
except hvac.exceptions.InvalidPath:
    sys.exit("Erreur : path inexistant dans Vault")
except hvac.exceptions.Forbidden:
    sys.exit("Erreur : permissions insuffisantes (verifie la policy)")
except hvac.exceptions.VaultError as e:
    sys.exit(f"Erreur Vault : {e}")
